# dependencies
node_modules/

# secrets — real values live only in app/.env (never committed)
app/.env

# runtime state — recreated automatically on first run, not source
app/data/players.json
app/data/usedThemes.json
# accounts.json holds password hashes (never plaintext, see accountsStore.js)
# but still shouldn't sit in a public repo -- recreated fresh (re-seeding the
# DimaSh admin account) on first server start, same as the two files above
app/data/accounts.json

# user-submitted SiGame packs ("Закинь українізовану SiGame" button) — may
# contain copyrighted third-party media, same reasoning as reference/ below;
# dima reviews these locally, they're never meant for the public repo
app/data/submittedPacks/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# stray log from local smoke-testing
app/server_smoke.log

# large private reference pack — not meant for public distribution
reference/
