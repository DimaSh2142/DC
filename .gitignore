# dependencies
node_modules/

# secrets — real values live only in app/.env (never committed)
app/.env

# runtime state — recreated automatically on first run, not source
app/data/players.json
app/data/usedThemes.json
# accounts.json holds password hashes (never plaintext, see accountsStore.js)
# but still shouldn't sit in a public repo -- recreated fresh (re-seeding the
# DimaSh admin account) on first server start, same as the two files above
app/data/accounts.json
# per-player activity log (2026-07-22 cabinet rebuild, src/state/activityStore.js)
# -- same "runtime state, not source" reasoning as the three files above
app/data/activity.json
# player-submitted ideas/complaints ("система репортів", 2026-07-22,
# src/state/reportsStore.js) -- same "runtime state, not source" reasoning
app/data/reports.json
# orphaned temp files from jsonStore.js's write-then-rename atomic-write
# pattern (data/*.json.tmp-<pid>-<ts>) -- only left behind if the process
# gets killed mid-write between the write and the rename; harmless, but
# shouldn't clutter git status if one is ever lying around
app/data/*.tmp-*

# user-submitted SiGame packs ("Закинь українізовану SiGame" button) — may
# contain copyrighted third-party media, same reasoning as reference/ below;
# dima reviews these locally, they're never meant for the public repo
app/data/submittedPacks/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Python bytecode cache (renderVoxToPng.py, run ad-hoc for texture rendering,
# not part of the running app -- see app/scripts/renderVoxToPng.py)
__pycache__/
*.pyc

# stray log from local smoke-testing
app/server_smoke.log

# large private reference pack — not meant for public distribution
reference/

# raw asset dumps dima drops in between sessions (zips/rars/vox source
# files) -- staging only, never the final committed asset. Whatever gets
# actually used ends up processed (e.g. rendered to PNG) under app/public/img/
# or app/public/audio/ instead, same pattern as every other asset pack.
_staging_assets/
